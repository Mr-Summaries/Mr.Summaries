# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# APPWRITE_API_KEY: Required for server-side Appwrite operations.
# Create this in the Appwrite console under Project Settings -> API Keys.
APPWRITE_API_KEY="YOUR_APPWRITE_API_KEY"
APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
APPWRITE_PROJECT_ID="YOUR_PROJECT_ID"
APPWRITE_DATABASE_ID="mr-summaries-db"
APPWRITE_COURSES_COLLECTION_ID="courses"
APPWRITE_SUMMARIES_COLLECTION_ID="summaries"
APPWRITE_LECTURES_COLLECTION_ID="lectures"
APPWRITE_EXAMPLES_COLLECTION_ID="examples"
APPWRITE_ENROLLMENTS_COLLECTION_ID="enrollments"
APPWRITE_ADMINS_COLLECTION_ID="admins"
APPWRITE_STORAGE_BUCKET_ID="summaries-bk"
SESSION_SECRET="YOUR_SESSION_SECRET"
